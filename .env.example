# ─────────────────────────────────────────────────────────────────────
# Copia este archivo como  .env  y rellena los valores
# ─────────────────────────────────────────────────────────────────────

# ── Telegram Bot ──────────────────────────────────────────────────────
# Obtén el token hablando con @BotFather en Telegram
TELEGRAM_TOKEN=AQUI_TU_TOKEN_DE_BOTFATHER

# ── Correo IMAP ───────────────────────────────────────────────────────
# Servidor IMAP (ej. imap.gmail.com, imap.outlook.com)
IMAP_HOST=imap.gmail.com
# Tu dirección de correo (la que usarás para enviar los libros)
IMAP_USER=tuemail@gmail.com
# Contraseña de aplicación (Gmail: https://myaccount.google.com/apppasswords)
IMAP_PASS=AQUI_CONTRASENA_DE_APP
# Puerto IMAP (993 = SSL, 143 = sin SSL)
IMAP_PORT=993
# Cada cuántos segundos revisa el buzón (120 = 2 minutos)
POLL_INTERVAL=120

# ── Calibre-Web (credenciales de tu cuenta admin) ─────────────────────
CALIBRE_USER=admin
CALIBRE_PASS=admin123
